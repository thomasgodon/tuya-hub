# tuya-hub runtime configuration (Docker).
#
# Copy to `.env` and fill in real values. `.env` is git-ignored (`*.env`).
# These override the shipped appsettings.json via .NET's double-underscore
# environment-variable binding (Host.CreateApplicationBuilder reads env vars).
# The shipped appsettings.json keeps everything Enabled=false; enable here.

# --- Web status dashboard ----------------------------------------------------
# Read-only page listing every configured device with its live state, served
# over the host network at http://<host>:<Port>/. Disable to run headless.
DashboardOptions__Enabled=true
DashboardOptions__Port=8080

# --- KNX gateway (KNXnet/IP tunnelling) -------------------------------------
KnxOptions__Enabled=true
KnxOptions__Host=192.168.0.10
KnxOptions__Port=3671
KnxOptions__IndividualAddress=1.1.100
KnxOptions__ReconnectInitialBackoffSeconds=1
KnxOptions__ReconnectMaxBackoffSeconds=30

# --- Tuya global tunables ----------------------------------------------------
TuyaOptions__PollIntervalSeconds=10
TuyaOptions__HeartbeatIntervalSeconds=10
TuyaOptions__LivenessTimeoutSeconds=30
TuyaOptions__ConnectTimeoutSeconds=5
TuyaOptions__ReconnectInitialBackoffSeconds=1
TuyaOptions__ReconnectMaxBackoffSeconds=30

# --- Tuya device 0 (repeat with __1__, __2__ ... for more devices) ----------
TuyaOptions__Devices__0__Enabled=true
TuyaOptions__Devices__0__Name=LivingRoomFan
TuyaOptions__Devices__0__IpAddress=192.168.0.50
TuyaOptions__Devices__0__DeviceId=REPLACE_WITH_DEVICE_ID
TuyaOptions__Devices__0__LocalKey=REPLACE_WITH_LOCAL_KEY
TuyaOptions__Devices__0__ProtocolVersion=3.3
TuyaOptions__Devices__0__Port=6668

# --- KNX group-address map --------------------------------------------------
# Keyed by the device Name above (DeviceMappings__<Name>__<Function>).
# An empty value disables that function. Command and status GAs are separate.
DeviceMappings__LivingRoomFan__FanPowerCommand=1/1/1
DeviceMappings__LivingRoomFan__FanPowerStatus=1/1/2
DeviceMappings__LivingRoomFan__FanSpeedStep=1/1/3
DeviceMappings__LivingRoomFan__FanSpeedStatus=1/1/4
DeviceMappings__LivingRoomFan__FanDirectionCommand=1/1/5
DeviceMappings__LivingRoomFan__FanDirectionStatus=1/1/6
DeviceMappings__LivingRoomFan__FanTimerCommand=1/1/7
DeviceMappings__LivingRoomFan__FanTimerStatus=1/1/8
DeviceMappings__LivingRoomFan__LightPowerCommand=1/1/9
DeviceMappings__LivingRoomFan__LightPowerStatus=1/1/10
DeviceMappings__LivingRoomFan__LightBrightnessCommand=1/1/11
DeviceMappings__LivingRoomFan__LightBrightnessStatus=1/1/12
DeviceMappings__LivingRoomFan__LightCctCommand=1/1/13
DeviceMappings__LivingRoomFan__LightCctStatus=1/1/14
DeviceMappings__LivingRoomFan__AvailabilityStatus=1/1/15

# --- Container timezone (optional) ------------------------------------------
TZ=Europe/Brussels
